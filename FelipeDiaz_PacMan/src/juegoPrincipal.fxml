<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>


<AnchorPane
    fx:id="rootPane"
    style="-fx-background-color: black;"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="JuegoController">

    <children>

        <ImageView fitHeight="38.0" fitWidth="110.0"
                layoutX="8.0" layoutY="8.0"
                pickOnBounds="true" preserveRatio="true">
            <image><Image url="@Imagenes%20usadas/Pac-Man-Logo.png"/></image>
        </ImageView>

    
        <Label layoutX="160.0" layoutY="13.0" text="PUNTOS:" textFill="#fff200">
            <font><Font name="Showcard Gothic" size="13.0"/></font>
        </Label>
        <Label fx:id="labelPuntuacion" layoutX="258.0" layoutY="13.0"
            text="0" textFill="white">
            <font><Font name="Showcard Gothic" size="13.0"/></font>
        </Label>

        
        <Label layoutX="360.0" layoutY="13.0" text="VIDAS:" textFill="#fff200">
            <font><Font name="Showcard Gothic" size="13.0"/></font>
        </Label>
        <HBox fx:id="hboxVidas" layoutX="425.0" layoutY="8.0" spacing="4.0">
            <children>
                <ImageView fx:id="vida1" fitHeight="28.0" fitWidth="28.0"
                        pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@Imagenes%20usadas/pacman.gif"/></image>
                </ImageView>
                <ImageView fx:id="vida2" fitHeight="28.0" fitWidth="28.0"
                        pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@Imagenes%20usadas/pacman.gif"/></image>
                </ImageView>
                <ImageView fx:id="vida3" fitHeight="28.0" fitWidth="28.0"
                        pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@Imagenes%20usadas/pacman.gif"/></image>
                </ImageView>
            </children>
        </HBox>

    
        <GridPane fx:id="tablero"
                gridLinesVisible="false"
                style="-fx-background-color: black;"/>

        
        <Label fx:id="labelMensaje"
            alignment="CENTER"
            prefWidth="400.0"
            text="ENTER PARA INICIAR"
            textFill="#fff200"
            visible="true">
            <font><Font name="Showcard Gothic" size="18.0"/></font>
        </Label>

    </children>
</AnchorPane>
